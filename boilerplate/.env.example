# ============================================================
# Environment Variables — copy this file to .env and fill in
# ============================================================

# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/myapp?schema=public

# Public base URL (used for absolute redirects / og-image URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Add application-specific variables below this line ----
