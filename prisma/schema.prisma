generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MASTER
  ADMIN
  KAPRODI
  KOORDINATOR
  DOSEN
  PRODI
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum RpsStatus {
  UNSUBMITTED
  SUBMITTED
  PENGECEKAN
  REVISION
  APPROVED
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocType {
  RPS
  SOAL_UTS
  SOAL_UAS
  LPP
  EPP
  BERITA_ACARA
}

enum DocStatus {
  UNSUBMITTED
  SUBMITTED
  PENGECEKAN
  REVISION
  APPROVED
}

model User {
  id                  String     @id @default(cuid())
  email               String     @unique
  password            String
  roles               Role[]     @default([DOSEN])
  name                String
  status              UserStatus @default(PENDING)
  savedSignature      String?    // base64 PNG data URL of saved signature
  rps                       RPS[]              @relation("DosenRPS")
  koordinatorReviews        RPS[]              @relation("KoordinatorReview")
  dosenMatkuls              Matkul[]           @relation("DosenMatkul")
  koordinatorMatkuls        Matkul[]           @relation("KoordinatorMatkul")
  academicDocs              AcademicDocument[] @relation("DosenAcademicDocs")
  koordinatorDocReviews     AcademicDocument[] @relation("KoordinatorAcademicReview")
  prodiDocReviews           AcademicDocument[] @relation("ProdiAcademicReview")
  matkulClasses             MatkulClass[]      @relation("ClassDosen")
  kelasDosenPa              Kelas[]                @relation("DosenPaKelas")
  prodiBAPReviews           BeritaAcaraPerwalian[] @relation("ProdiBAP")
  notifications             Notification[]
  changeRequests            MatkulChangeRequest[]
}

model TahunAkademik {
  id        String     @id @default(cuid())
  tahun     String     @unique  // "2025/2026"
  isActive  Boolean    @default(false)
  semesters Semester[]
}

model Semester {
  id              String        @id @default(cuid())
  tahunAkademikId String
  tahunAkademik   TahunAkademik @relation(fields: [tahunAkademikId], references: [id], onDelete: Cascade)
  nama            String        // "Ganjil" | "Genap" | "Akselerasi"
  isActive        Boolean       @default(false)
  matkuls         Matkul[]
  academicDocs    AcademicDocument[]
  baps            BeritaAcaraPerwalian[]

  @@unique([tahunAkademikId, nama])
}

model KatalogMatkul {
  id             String                @id @default(cuid())
  code           String                @unique
  name           String
  sks            Int
  matkuls        Matkul[]
  changeRequests MatkulChangeRequest[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model Matkul {
  id              String               @id @default(cuid())
  code            String
  name            String
  sks             Int
  semesterId      String?
  semester        Semester?            @relation(fields: [semesterId], references: [id])
  katalogMatkulId String?
  katalogMatkul   KatalogMatkul?       @relation(fields: [katalogMatkulId], references: [id])
  dosens          User[]               @relation("DosenMatkul")
  koordinators    User[]               @relation("KoordinatorMatkul")
  classes         MatkulClass[]
  rps             RPS[]
  academicDocs    AcademicDocument[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([code, semesterId])
}

model MatkulClass {
  id       String  @id @default(cuid())
  matkulId String
  matkul   Matkul  @relation(fields: [matkulId], references: [id], onDelete: Cascade)
  name     String  // e.g. "23TI1", "23TI2"
  dosens   User[]  @relation("ClassDosen")

  @@unique([matkulId, name])
}


model MatkulChangeRequest {
  id                String              @id @default(cuid())
  katalogMatkulId   String
  katalogMatkul     KatalogMatkul       @relation(fields: [katalogMatkulId], references: [id])
  requestedById     String?
  requestedBy       User?               @relation(fields: [requestedById], references: [id])
  proposedName      String?
  proposedCode      String?
  proposedSks       Int?
  reason            String?
  status            ChangeRequestStatus @default(PENDING)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model RPS {
  id                      String    @id @default(cuid())
  matkulId                String
  matkul                  Matkul    @relation(fields: [matkulId], references: [id])
  fileUrl                 String?
  fileName                String?
  status                  RpsStatus @default(UNSUBMITTED)
  notes                   String?
  isKoordinatorApproved   Boolean   @default(false)
  koordinatorId           String?
  koordinator             User?     @relation("KoordinatorReview", fields: [koordinatorId], references: [id])
  koordinatorNotes        String?
  kaprodiNotes            String?
  annotatedPdfUrl         String?   // PDF with annotations burned in (set on rejection)
  // Koordinator digital signature fields
  koordinatorSigUrl       String?   // stored signature image URL
  koordinatorSigX         Float?    // X position as % of page width (0–100)
  koordinatorSigY         Float?    // Y position as % of page height (0–100)
  koordinatorSigPage      Int?      // 1-based page number
  koordinatorSigWidth     Float?    // signature width as % of page width
  koordinatorSignedPdfUrl String?   // PDF after koordinator stamps signature
  // Kaprodi digital signature fields
  kaprodiSigUrl           String?
  kaprodiSigX             Float?
  kaprodiSigY             Float?
  kaprodiSigPage          Int?
  kaprodiSigWidth         Float?
  finalPdfUrl             String?   // fully signed PDF (after kaprodi stamps)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  dosenId                 String
  dosen                   User      @relation("DosenRPS", fields: [dosenId], references: [id])
  annotations             RpsAnnotation[]
}

model AcademicDocument {
  id       String    @id @default(cuid())
  matkulId String
  matkul   Matkul    @relation(fields: [matkulId], references: [id])
  dosenId  String
  dosen    User      @relation("DosenAcademicDocs", fields: [dosenId], references: [id])
  semesterId String?
  semester   Semester? @relation(fields: [semesterId], references: [id])

  type    DocType
  fileUrl  String?
  fileName String?
  annotatedPdfUrl String?

  status                DocStatus @default(UNSUBMITTED)
  isKoordinatorApproved Boolean   @default(false)
  koordinatorId         String?
  koordinator           User?     @relation("KoordinatorAcademicReview", fields: [koordinatorId], references: [id])
  koordinatorNotes      String?
  kaprodiNotes          String?

  koordinatorSigUrl       String?
  koordinatorSigPage      Int?
  koordinatorSigX         Float?
  koordinatorSigY         Float?
  koordinatorSigWidth     Float?
  koordinatorSignedPdfUrl String?

  kaprodiSigUrl   String?
  kaprodiSigPage  Int?
  kaprodiSigX     Float?
  kaprodiSigY     Float?
  kaprodiSigWidth Float?
  finalPdfUrl     String?

  isProdiApproved Boolean  @default(false)
  prodiId         String?
  prodi           User?    @relation("ProdiAcademicReview", fields: [prodiId], references: [id])
  prodiNotes      String?

  annotations AcademicDocAnnotation[]

  // EPP-specific fields (nullable, only used when type = EPP)
  eppPersentaseMateri     Float?
  eppPersentaseCpmk       Float?
  eppPersentaseKehadiran  Float?
  eppPersentaseNilaiB     Float?
  eppPersentaseKkmToB     Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matkulId, dosenId, semesterId, type])
}

model Kelas {
  id        String   @id @default(cuid())
  name      String   @unique
  dosenPaId String
  dosenPa   User     @relation("DosenPaKelas", fields: [dosenPaId], references: [id])
  baps      BeritaAcaraPerwalian[]
  createdAt DateTime @default(now())
}

model BeritaAcaraPerwalian {
  id         String   @id @default(cuid())
  kelasId    String
  kelas      Kelas    @relation(fields: [kelasId], references: [id])
  semesterId String
  semester   Semester @relation(fields: [semesterId], references: [id])

  lembarKehadiranUrl  String?
  lembarKehadiranName String?
  absensiUrl          String?
  absensiName         String?
  beritaAcaraUrl      String?
  beritaAcaraName     String?

  isUnlocked      Boolean   @default(false)
  status          DocStatus @default(UNSUBMITTED)
  isProdiApproved Boolean   @default(false)
  prodiId         String?
  prodi           User?     @relation("ProdiBAP", fields: [prodiId], references: [id])
  prodiNotes      String?
  kaprodiNotes    String?
  finalApprovedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([kelasId, semesterId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model AcademicDocAnnotation {
  id           String           @id @default(cuid())
  docId        String
  doc          AcademicDocument @relation(fields: [docId], references: [id], onDelete: Cascade)
  type         String
  page         Int
  x            Float
  y            Float
  width        Float?
  height       Float?
  color        String   @default("#FFD700")
  content      String?
  pathData     String?
  reviewerRole String
  createdAt    DateTime @default(now())
}

model RpsAnnotation {
  id           String   @id @default(cuid())
  rpsId        String
  rps          RPS      @relation(fields: [rpsId], references: [id], onDelete: Cascade)
  type         String   // "highlight" | "draw" | "box" | "sticky"
  page         Int      // 1-based page number
  x            Float    // % of page width (left edge)
  y            Float    // % of page height (top edge)
  width        Float?   // % of page width (highlight/box)
  height       Float?   // % of page height (highlight/box)
  color        String   @default("#FFD700")
  content      String?  // sticky note text
  pathData     String?  // JSON array of {x,y}[] in % coords for draw type
  reviewerRole String   // "koordinator" | "kaprodi"
  createdAt    DateTime @default(now())
}
