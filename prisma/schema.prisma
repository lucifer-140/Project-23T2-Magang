generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MASTER
  ADMIN
  KAPRODI
  KOORDINATOR
  DOSEN
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum RpsStatus {
  UNSUBMITTED
  SUBMITTED
  PENGECEKAN
  REVISION
  APPROVED
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                  String     @id @default(cuid())
  email               String     @unique
  password            String
  roles               Role[]     @default([DOSEN])
  name                String
  status              UserStatus @default(PENDING)
  savedSignature      String?    // base64 PNG data URL of saved signature
  rps                    RPS[]    @relation("DosenRPS")
  koordinatorReviews     RPS[]    @relation("KoordinatorReview")
  dosenMatkuls           Matkul[] @relation("DosenMatkul")
  koordinatorMatkuls     Matkul[] @relation("KoordinatorMatkul")
}

model Matkul {
  id              String               @id @default(cuid())
  code            String               @unique
  name            String
  sks             Int
  dosens          User[]               @relation("DosenMatkul")
  koordinators    User[]               @relation("KoordinatorMatkul")
  rps             RPS[]
  changeRequests  MatkulChangeRequest[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model MatkulChangeRequest {
  id            String              @id @default(cuid())
  matkulId      String
  matkul        Matkul              @relation(fields: [matkulId], references: [id])
  proposedName  String?
  proposedCode  String?
  proposedSks   Int?
  reason        String?
  status        ChangeRequestStatus @default(PENDING)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model RPS {
  id                      String    @id @default(cuid())
  matkulId                String
  matkul                  Matkul    @relation(fields: [matkulId], references: [id])
  fileUrl                 String?
  fileName                String?
  status                  RpsStatus @default(UNSUBMITTED)
  notes                   String?
  isKoordinatorApproved   Boolean   @default(false)
  koordinatorId           String?
  koordinator             User?     @relation("KoordinatorReview", fields: [koordinatorId], references: [id])
  koordinatorNotes        String?
  kaprodiNotes            String?
  annotatedPdfUrl         String?   // PDF with annotations burned in (set on rejection)
  // Koordinator digital signature fields
  koordinatorSigUrl       String?   // stored signature image URL
  koordinatorSigX         Float?    // X position as % of page width (0–100)
  koordinatorSigY         Float?    // Y position as % of page height (0–100)
  koordinatorSigPage      Int?      // 1-based page number
  koordinatorSigWidth     Float?    // signature width as % of page width
  koordinatorSignedPdfUrl String?   // PDF after koordinator stamps signature
  // Kaprodi digital signature fields
  kaprodiSigUrl           String?
  kaprodiSigX             Float?
  kaprodiSigY             Float?
  kaprodiSigPage          Int?
  kaprodiSigWidth         Float?
  finalPdfUrl             String?   // fully signed PDF (after kaprodi stamps)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  dosenId                 String
  dosen                   User      @relation("DosenRPS", fields: [dosenId], references: [id])
  annotations             RpsAnnotation[]
}

model RpsAnnotation {
  id           String   @id @default(cuid())
  rpsId        String
  rps          RPS      @relation(fields: [rpsId], references: [id], onDelete: Cascade)
  type         String   // "highlight" | "draw" | "box" | "sticky"
  page         Int      // 1-based page number
  x            Float    // % of page width (left edge)
  y            Float    // % of page height (top edge)
  width        Float?   // % of page width (highlight/box)
  height       Float?   // % of page height (highlight/box)
  color        String   @default("#FFD700")
  content      String?  // sticky note text
  pathData     String?  // JSON array of {x,y}[] in % coords for draw type
  reviewerRole String   // "koordinator" | "kaprodi"
  createdAt    DateTime @default(now())
}
